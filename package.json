{
  "name": "plot-money",
  "private": true,
  "version": "0.1.0",
  "description": "MCP-first personal finance backend for India",
  "license": "MIT",
  "homepage": "https://plot.money",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msomu/plot-money.git"
  },
  "bugs": {
    "url": "https://github.com/msomu/plot-money/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
