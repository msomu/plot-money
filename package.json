    "build": "bun run --filter '*' build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11"
}
