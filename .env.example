# plot.money — environment variables (template)
#
# v0.1 runs entirely on Cloudflare. Bindings (D1 + R2) live in
# apps/api/wrangler.toml; secrets go in `apps/api/.env.local` for local
# dev (gitignored) and `wrangler secret put <NAME>` for prod.
#
# Web app (apps/web) reads no secrets directly — Better Auth lives in the
# API and the dashboard talks to it via same-origin proxy in dev / shared
# subdomain in prod.

# ---------- API (apps/api) ----------

# Better Auth — signs sessions and CSRF tokens. Stable; rotating it
# invalidates all sessions. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=

# Salt for HMAC-hashing MCP bearer tokens. Stable; rotating invalidates
# all issued tokens. Generate with `openssl rand -hex 32`.
APP_SECRET=

# Google OAuth client (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URIs (add ALL of these to the Cloud Console):
#   http://localhost:3000/api/auth/callback/google      (local dev)
#   https://plot.money/api/auth/callback/google         (production)
#   https://p.plot.money/api/auth/callback/google       (preview)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay Checkout. Use test keys locally/preview; production keys only when
# real billing is ready.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- Web (apps/web) — public, no secrets ----------

PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://app.posthog.com
