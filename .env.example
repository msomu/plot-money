# plot.money — Environment variables (template)
# Copy to .env.local in each app dir. NEVER commit real values.

# ---------- API (apps/api) ----------

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Postgres (Neon) — get from https://console.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# App role used by request-scoped queries (RLS-bound, NOT superuser)
DATABASE_APP_ROLE=plot_app
DATABASE_APP_ROLE_PASSWORD=

# Secret used to hash MCP bearer tokens before storage (sha256 with this as salt).
# Generate: openssl rand -hex 32
APP_SECRET=

# Better Auth — Google OAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (TEST MODE for v0.1)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=plan_XXXXXXXXXXXX

# OpenRouter (Gemini 2.5 Flash Lite for transaction categorization)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ---------- Web (apps/web) ----------

PUBLIC_API_URL=http://localhost:3000
PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://app.posthog.com
